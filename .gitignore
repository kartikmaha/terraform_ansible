# ==========================================
# IDE & System Files
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ==========================================
# Credentials & Secrets (CRITICAL)
# ==========================================
*.pem
*.key
*.ppk
terra-key
secrets/
.env
.env.*
!.env.example

# ==========================================
# Terraform Specific
# ==========================================
# Local config and plugins
.terraform/
.terraform.lock.hcl

# State files (Should be in S3, never Git)
*.tfstate
*.tfstate.*

# Variable files (Sensitive data)
*.tfvars
*.tfvars.json
# Allow example files for documentation
!*.tfvars.example

# Overrides & Crashes
override.tf
override.tf.json
*_override.tf
*_override.tf.json
crash.log

# ==========================================
# Application & Logs
# ==========================================
*.log
node_modules/
dist/
build/
tmp/
temp/
outputs.txt
deployment-outputs.txt